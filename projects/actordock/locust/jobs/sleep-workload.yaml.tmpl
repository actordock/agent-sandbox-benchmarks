apiVersion: batch/v1
kind: Job
metadata:
  name: locust-sleep-workload
  namespace: monitoring
spec:
  backoffLimit: 0
  template:
    metadata:
      labels:
        app: locust-sleep-workload
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "8000"
    spec:
      restartPolicy: Never
      containers:
      - name: locust
        image: ${LOCUST_IMAGE}
        command: ["/bin/sh", "-c"]
        args:
        - |
          python3 -m locust \
            -f "/app/tests/sleep.py,/app/shapes/burst_shape.py" \
            --headless \
            --run-time "${BENCH_RUN_TIME}" \
            --csv /tmp/locust/out \
            --only-summary \
            --exit-code-on-error 0
          sleep 20
        ports:
        - name: metrics
          containerPort: 8000
        volumeMounts:
        - name: servicedns-ca
          mountPath: /run/servicedns-ca
          readOnly: true
        - name: results
          mountPath: /tmp/locust
      volumes:
      - name: results
        emptyDir: {}
      - name: servicedns-ca
        projected:
          sources:
          - clusterTrustBundle:
              signerName: servicedns.podcert.actordock.dev/identity
              labelSelector:
                matchLabels:
                  podcert.actordock.dev/canarying: live
              path: ca.crt
